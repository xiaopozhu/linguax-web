{
    "name": "linguax-web",
    "main": "worker/index.js",
    "compatibility_date": "2024-01-01",
    "site": {
      "bucket": "./build",    // 指向 Docusaurus 的构建输出目录
    },
    "routes": [
      { "pattern": "linguax.app/*", "zone_name": "linguax.app" }
    ],
    "vars": {
      "API_BASE_URL": "https://api.linguax.app" // 可选：后端 API 地址
    }
  }